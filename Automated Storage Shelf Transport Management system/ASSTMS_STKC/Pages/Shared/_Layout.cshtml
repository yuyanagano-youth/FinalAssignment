<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>AMHS Control Panel</title>
    <script src="@("https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4")"> </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-slate-900 text-slate-100 font-sans min-h-screen flex flex-col pb-20 selection:bg-indigo-500 selection:text-white">

    <header class="bg-slate-950 border-b border-slate-800 sticky top-0 z-50 shadow-md px-4 py-3">
        <div class="max-w-md mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2">
                <i class="fa-solid mt-0.5 fa-microchip text-indigo-400 text-xl animate-pulse"></i>
                <h1 class="text-md font-bold tracking-wider text-slate-200">STKC SIMULATOR</h1>
            </div>
            <div id="connectionMasterBadge" class="px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/30 flex items-center gap-1.5">
                <span class="h-2 w-2 rounded-full bg-emerald-400 animate-ping"></span>
                SYSTEM ACTIVE
            </div>
        </div>
    </header>

    <div id="toastAlert" class="fixed top-16 left-1/2 -translate-x-1/2 w-full max-w-sm px-4 z-50 pointer-events-none transition-all duration-300 transform scale-95 opacity-0 hidden">
        <div id="toastContent" class="bg-slate-950 border text-sm shadow-2xl rounded-xl p-3.5 flex items-start gap-3 text-slate-200"></div>
    </div>

    <main role="main" class="flex-1 w-full max-w-md mx-auto px-4 py-4 overflow-x-hidden">
        @RenderBody()
    </main>

    <nav class="fixed bottom-0 left-0 right-0 bg-slate-950 border-t border-slate-800 shadow-2xl z-50">
        <div class="max-w-md mx-auto grid grid-cols-5 h-16 items-center text-center">
            <a href="/" class="nav-link flex flex-col items-center justify-center text-slate-400 hover:text-indigo-400 transition-colors gap-1">
                <i class="fa-solid fa-gamepad text-lg"></i><span class="text-[10px] font-medium">メイン操作</span>
            </a>
            <a href="/Stockers" class="nav-link flex flex-col items-center justify-center text-slate-400 hover:text-indigo-400 transition-colors gap-1">
                <i class="fa-solid fa-layer-group text-lg"></i><span class="text-[10px] font-medium">装置一覧</span>
            </a>
            <a href="/Shelves" class="nav-link flex flex-col items-center justify-center text-slate-400 hover:text-indigo-400 transition-colors gap-1">
                <i class="fa-solid fa-table-cells text-lg"></i><span class="text-[10px] font-medium">棚・在庫</span>
            </a>
            <a href="/Jobs" class="nav-link flex flex-col items-center justify-center text-slate-400 hover:text-indigo-400 transition-colors gap-1">
                <i class="fa-solid fa-clock-rotate-left text-lg"></i><span class="text-[10px] font-medium">ジョブ監視</span>
            </a>
            <a href="/History" class="nav-link flex flex-col items-center justify-center text-slate-400 hover:text-indigo-400 transition-colors gap-1">
                <i class="fa-solid fa-list-ul text-lg"></i><span class="text-[10px] font-medium">履歴ログ</span>
            </a>
        </div>
    </nav>

    <script src="~/js/stkc-core.js" asp-append-version="true"></script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
