<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <!--
        スマートフォン(Android 16:9想定)専用のビューポート設定。
        ネイティブアプリ風の操作感を出すため、ピンチズーム・二重タップズームは無効化する。
    -->
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
    <meta name="theme-color" content="#0d1b2a" />
    <title>@ViewData["Title"] - 自動保管棚管理システム</title>

    <!-- ===== PWA設定: マニフェスト & アイコン ===== -->
    <link rel="manifest" href="~/manifest.json" />
    <link rel="apple-touch-icon" href="~/icons/icon-192.png" />
    <link rel="icon" type="image/png" href="~/icons/icon-192.png" />

    <!-- Bootstrap 5 (CDN) : カードUI・グリッド・ユーティリティクラス用 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons (CDN) : ボトムナビ用アイコン -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />

    <!-- 自前のApp Shell用スタイル -->
    <link rel="stylesheet" href="~/css/site.css"/>
</head>
<body>

    <!-- ============================================================
         App Shell ヘッダー（共通ステータスブロック）
         必要に応じて各ページ側のJSがここにバナー通知などを追加する。
    ============================================================= -->
    <header class="app-header">
        <span class="app-header-title">自動保管棚管理システム</span>
        <span id="globalConnIndicator" class="conn-indicator" title="フロントエンド⇔サーバー間の通信状態">
            <i class="bi bi-circle-fill"></i>
        </span>
    </header>

    <!-- ============================================================
         メインコンテンツ（各 Pages/*.cshtml が描画される領域）
         ヘッダー高さ＋ボトムナビ高さ分のpaddingはsite.cssで調整。
    ============================================================= -->
    <main class="app-main">
        @RenderBody()
    </main>

    <!-- ============================================================
         固定ボトムナビゲーションバー（App Shell / 5タブ構成）
         現在のページに active クラスを付与してハイライトする。
    ============================================================= -->
    <nav class="bottom-nav">
        <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" href="/Index">
            <i class="bi bi-speedometer2"></i>
            <span>Main</span>
        </a>
        <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Stockers" ? "active" : "")" href="/Stockers">
            <i class="bi bi-hdd-stack"></i>
            <span>Stockers</span>
        </a>
        <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Jobs" ? "active" : "")" href="/Jobs">
            <i class="bi bi-list-task"></i>
            <span>Jobs</span>
        </a>
        <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/Shelves" ? "active" : "")" href="/Shelves">
            <i class="bi bi-grid-3x3-gap"></i>
            <span>Shelves</span>
        </a>
        <a class="nav-item @(ViewContext.RouteData.Values["page"]?.ToString() == "/History" ? "active" : "")" href="/History">
            <i class="bi bi-clock-history"></i>
            <span>History</span>
        </a>
    </nav>

    <!-- ============================================================
         トースト通知エリア（共通：ジョブ送信成功時など）
    ============================================================= -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1080; margin-bottom: 70px;">
        <div id="globalToast" class="toast align-items-center text-bg-success border-0" role="alert">
            <div class="d-flex">
                <div class="toast-body" id="globalToastBody">処理が完了しました</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS (トースト等のコンポーネント制御に使用) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!--
        ===== 決定ファイル: amhs-core.js =====
        全ページ共通の通信モジュール。バックエンドAPI呼び出しと
        モック(virtual JSON server)切り替えロジックをここに集約する。
        mock-server.js → amhs-core.js の順で読み込むこと（依存関係）。
    -->
    <script src="~/js/mock-server.js"></script>
    <script src="~/js/amhs-core.js"></script>

    @RenderSection("Scripts", required: false)

    <script>
        // ===== PWA: Service Worker 登録 =====
        // オフライン時でもApp Shell自体は表示できるようにキャッシュ制御する。
        // if ('serviceWorker' in navigator) {
        // window.addEventListener('load', () => {
        // navigator.serviceWorker.register('/sw.js')
        // .then(reg => console.log('[PWA] Service Worker registered:', reg.scope))
        // .catch(err => console.error('[PWA] Service Worker registration failed:', err));
        // });
        // }
    </script>
</body>
</html>
